<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Ecommerce Suite"
       parallel="tests"
       thread-count="2">

    <listeners>
        <listener class-name="com.ecommerce.automation.listeners.AllureListener"/>
        <listener class-name="com.ecommerce.automation.listeners.ScreenshotListener"/>
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="com.ecommerce.automation.tests.UI.LoginTest"/>
            <class name="com.ecommerce.automation.tests.UI.AddToCartTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="com.ecommerce.automation.tests.API.APITest"/>
        </classes>
    </test>

</suite>